# Environment Configuration
# Copy this to .env and update values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_personalized
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ecommerce_personalized

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
DEBUG=True
APP_NAME=E-Commerce Personalization API

# Classification thresholds
BRAND_VIEW_THRESHOLD=5
PRICE_FILTER_THRESHOLD=3
INTERACTION_VIEW_THRESHOLD=20
OFFER_CLICK_THRESHOLD=5
PREMIUM_AVG_ORDER_THRESHOLD=5000.0
RECLASSIFICATION_INTERVAL_MINUTES=30

# Redis (optional)
# REDIS_URL=redis://localhost:6379/0
